{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Error"
    }
  },
  "AllowedHosts": "*",
  
  // Set your Azure Key Vault name here when deploying to Azure
  // Example: "KeyVaultName": "puzzletracker-kv"
  "KeyVaultName": "",
  
  // Connection strings should be stored in Azure Key Vault in production
  // The connection string will be loaded from Key Vault as a secret named "DefaultConnection"
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  
  // Configure allowed origins for your production environment
  "CorsSettings": {
    "AllowedOrigins": [
      "https://your-production-app.azurewebsites.net"
    ]
  },
  
  "ApplicationSettings": {
    "SwaggerEndpoint": "/swagger/v1/swagger.json",
    "SwaggerTitle": "PuzzleTracker API v1"
  }
}
