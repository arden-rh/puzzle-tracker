# Azure Configuration Environment Variables
# ===========================================
# This file demonstrates how to configure the application using environment variables
# following the 12-factor app methodology for cloud-native applications.
#
# IMPORTANT: Never commit actual secrets to source control!
# This is a TEMPLATE file showing the structure.

# ===========================
# Azure Key Vault Configuration
# ===========================
# Set your Azure Key Vault name (without .vault.azure.net suffix)
KeyVaultName=your-keyvault-name

# ===========================
# Database Connection
# ===========================
# In production, this should be retrieved from Key Vault as a secret named "DefaultConnection"
# For local development with Azure SQL:
ConnectionStrings__DefaultConnection=Server=tcp:your-server.database.windows.net,1433;Initial Catalog=PuzzleTrackerDB;Authentication=Active Directory Default;

# For local development with SQL Server:
# ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=PuzzleTrackerDB;Trusted_Connection=True;MultipleActiveResultSets=true

# ===========================
# CORS Configuration
# ===========================
# Comma-separated list of allowed origins
CorsSettings__AllowedOrigins__0=https://your-app.azurewebsites.net
CorsSettings__AllowedOrigins__1=https://your-custom-domain.com

# ===========================
# Application Settings
# ===========================
ApplicationSettings__SwaggerEndpoint=/swagger/v1/swagger.json
ApplicationSettings__SwaggerTitle=PuzzleTracker API v1

# ===========================
# Azure Authentication (for local development)
# ===========================
# These are used by DefaultAzureCredential when running locally
# Option 1: Service Principal (for CI/CD)
# AZURE_CLIENT_ID=your-client-id
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_SECRET=your-client-secret

# Option 2: Managed Identity (automatically available in Azure)
# No configuration needed - automatically uses the assigned managed identity

# Option 3: Azure CLI (for local development)
# Run: az login
# Then: az account set --subscription "your-subscription-id"

# ===========================
# ASP.NET Core Environment
# ===========================
ASPNETCORE_ENVIRONMENT=Production
# Options: Development, Staging, Production

# ===========================
# Logging Configuration
# ===========================
Logging__LogLevel__Default=Information
Logging__LogLevel__Microsoft.AspNetCore=Warning
Logging__LogLevel__Microsoft.EntityFrameworkCore=Warning

# ===========================
# Additional Azure Services (Examples)
# ===========================
# If using Azure App Configuration:
# AzureAppConfiguration__Endpoint=https://your-appconfig.azconfig.io

# If using Application Insights:
# ApplicationInsights__ConnectionString=InstrumentationKey=your-key;IngestionEndpoint=https://...

# If using Azure Storage:
# AzureStorage__AccountName=yourstorageaccount
# (Use Managed Identity instead of connection string)

# If using Azure Service Bus:
# AzureServiceBus__Namespace=your-namespace.servicebus.windows.net
# (Use Managed Identity instead of connection string)
